# Copy this file to `.env` and edit values for your local setup:
#   cp .env.sample .env
#
# `.env` is gitignored; `.env.sample` is committed.

DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# In production behind HTTPS, list every origin your app is served from,
# comma-separated and scheme-qualified, e.g.
#   CSRF_TRUSTED_ORIGINS=https://your-app.ondigitalocean.app,https://your-custom-domain.com
# Leave blank for local HTTP development.
CSRF_TRUSTED_ORIGINS=

# Connection used by `manage.py` when running OUTSIDE Docker (e.g. in a venv)
# against the Postgres started by `docker compose up`. Compose exposes the
# container's 5432 on host port 5433 to avoid colliding with a local Postgres.
#
# When the app itself runs INSIDE compose, docker-compose.yml sets its own
# DATABASE_URL (postgres://...@db:5432/...) — this value is not used there.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/party_invitations
